@model List<ToDoList>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Layout/Index.cshtml";
    int count = 0;
}

<div class="content">
    <div class="container-fluid">
        <h4 class="page-title">Yapılacaklar</h4>
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header">
                        <div class="card-title">Yapılacaklar Listesi</div>
                    </div>
                    <div class="card-body">
                        <div class="card-sub">
                            Yapılacaklar ile ilgili işlemleri aşağıdaki panelden yapabilirsiniz.
                        </div>
                        <table class="table mt-3">
                            <thead>
                                <tr>
                                    <th scope="col">#</th>
                                    <th scope="col">İçerik</th>
                                    <th scope="col">Tarih</th>
                                    <th scope="col">Durum</th>
                                    <th scope="col">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <td>@count</td>
                                        <td>@item.Title</td>
                                        <td>@item.Date.ToShortDateString()</td>
                                        <td>
                                            @if (item.Status == true)
                                            {
                                                <label class="text-success">(Yapıldı)&nbsp;&nbsp;</label>
                                                <a href="/ToDoList/ChangeToDoListStatus/@item.ToDoListId" class="btn btn-danger">Yapılmadı Yap</a>
                                            }
                                            else
                                            {
                                                <label class="text-danger">(Yapılmadı)&nbsp;&nbsp;</label>
                                                <a href="/ToDoList/ChangeToDoListStatus/@item.ToDoListId" class="btn btn-success">Yapıldı Yap</a>
                                            }
                                        </td>
                                        <td>
                                            <a href="/ToDoList/DeleteToDoList/@item.ToDoListId" class="btn btn-danger" title="Sil"><i class="la la-trash"></i></a>
                                            <a href="/ToDoList/UpdateToDoList/@item.ToDoListId" class="btn btn-info" title="Güncelle"><i class="la la-pencil"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <hr />
                        <a href="/ToDoList/CreateToDoList" class="btn btn-primary"><i class="la la-plus"></i>&nbsp;Görev Ekle</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>