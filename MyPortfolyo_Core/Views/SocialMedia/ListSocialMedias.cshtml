@model List<SocialMedia>
@{
    ViewData["Title"] = "ListSocialMedias";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="content">
    <div class="container-fluid">
        <h4 class="page-title">Sosyal Medya Hesapları</h4>
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header">
                        <div class="card-title">Hesap Listesi</div>
                    </div>
                    <div class="card-body">
                        <div class="card-sub">
                            Sosyal medya hesapları ile ilgili işlemleri aşağıdaki panelden yapabilirsiniz.
                        </div>
                        <table class="table mt-3">
                            <thead>
                                <tr>
                                    <th scope="col">Başlık</th>
                                    <th scope="col">Url</th>
                                    <th scope="col">Logo / Icon</th>
                                    <th scope="col">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.Title</td>
                                        <td>@item.Url</td>
                                        <td><span class="@item.Icon.Replace("im", "la")" style="font-size:22px"></span></td>
                                        <td>
                                            <a href="/SocialMedia/DeleteSocialMedias/@item.SocialMediaId" class="btn btn-danger" title="Sil"><i class="la la-trash"></i></a>
                                            <a href="/SocialMedia/UpdateSocialMedias/@item.SocialMediaId" class="btn btn-info" title="Güncelle"><i class="la la-pencil"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <hr />
                        <a href="/SocialMedia/AddSocialMedias" class="btn btn-primary"><i class="la la-plus"></i>&nbsp;Sosyal Medya Hesabı Ekle</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>