<!-- About (Hakkımda) Bölümü Default sayfası -->
@model List<MyPortfolyo_Core.DAL.Entities.About>
<section id="about" class="s-about target-section">

    <div class="row narrow section-intro has-bottom-sep">
        <div class="col-full text-center">
            <h3>Hakkımda</h3>
            <h1>@ViewBag.aboutTitle</h1>
            <p class="lead">@ViewBag.subDesc</p>
        </div>
    </div>

    <div class="row about-content">

        <div class="col-six tab-full left">
            <h3>Ben Kimim?</h3>

            <p>
                @ViewBag.aboutDetail
            </p>
        </div>

        <!-- Skill (Yetenekler) Kısmı -->
        @await Component.InvokeAsync("_SkillComponentPartial")

    </div> <!-- end about-content -->

    <div class="row about-content about-content--buttons">

        <div class="col-six tab-full left">
            <a href="~/Burak Can Yurdacan CV.pdf" download class="btn btn--primary full-width">CV İndir</a>
        </div>
        <div class="col-six tab-full right">
            <a href="#contact" class="btn full-width smoothscroll">Bana Yazın</a>
        </div>

    </div> <!-- end about-content buttons -->

    <!-- Experience (Deneyimlerim) Kısmı -->
    @await Component.InvokeAsync("_ExperienceComponentPartial")
     

</section>