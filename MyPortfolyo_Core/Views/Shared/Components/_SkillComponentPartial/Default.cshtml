<!-- Skills (Yeteneklerim) Bölümü Default sayfası -->

@model List<MyPortfolyo_Core.DAL.Entities.Skill>
<div class="col-six tab-full right">
    <h3>Programlama Dilleri & Teknolojiler</h3>

    <ul class="skill-bars">
        @foreach (var item in Model)
        {
            string valPerc = "percent" + item.Value;
            <li>
                <div class="progress @valPerc"><span>@item.Value</span></div>
                <strong>@item.Title</strong>
            </li>
        }
    </ul>
</div>