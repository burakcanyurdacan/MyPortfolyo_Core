<!-- Experience (Deneyimlerim) Bölümü Default sayfası -->
@model List<MyPortfolyo_Core.DAL.Entities.Experience>

<div class="row about-content about-content--timeline">

    <div class="col-full text-center">
        <h3>Is Deneyimlerim</h3>
    </div>


    @foreach (var item in Model)
    {
        <div class="col-six tab-full left">
            <div class="timeline">
                <div class="timeline__block">
                    <div class="timeline__bullet"></div>
                    <div class="timeline__header">
                        <p class="timeline__timeframe">@item.StartDate.ToString("MMMM/yyyy") - @(item.EndDate?.ToString("MMMM/yyyy") ?? "Devam Ediyor")</p>
                        <h3>@item.Head</h3>
                        <h5>@item.Title</h5>
                    </div>
                    <div class="timeline__desc">
                        <p>@item.Description</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>