@using MyPortfolyo_Core.DAL.Entities
<!-- Anasayfa Bölümü Default sayfası -->

@model DashboardViewModel

<section id="home" class="s-home page-hero target-section" data-parallax="scroll" data-image-src="../hola-master/images/bcy-bg.jpg" data-natural-width=3000 data-natural-height=2000 data-position-y=center>

    <div class="overlay"></div>
    <div class="shadow-overlay"></div>

    @foreach (var item in Model.Features)
    {
        <div class="home-content">

            <div class="row home-content__main">

                <h3>@item.Title</h3>

                <h1>
                    @item.Description
                </h1>

                <div class="home-content__buttons">
                    <a href="#works" class="smoothscroll btn btn--stroke">
                        Son Projeler
                    </a>
                    <a href="#about" class="smoothscroll btn btn--stroke">
                        Hakkımda
                    </a>
                </div>

                <div class="home-content__scroll">
                    <a href="#about" class="scroll-link smoothscroll">
                        <span>Aşağı in</span>
                    </a>
                </div>

            </div>

        </div>
    }

    <!-- end home-content -->

    <ul class="home-social">
        @foreach (var item in Model.SocialMedias)
        {
            <li>
                <a href="@item.Url" target="_blank"><i class="@item.Icon" aria-hidden="true"></i><span>@item.Title</span></a>
            </li>
        }
    </ul>
    <!-- end home-social -->

</section>