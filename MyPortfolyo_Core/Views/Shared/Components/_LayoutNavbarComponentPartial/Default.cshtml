@model List<ToDoList>

<div class="main-header">
	<div class="logo-header">
		<a href="#" class="logo">
			Admin Paneli
		</a>		
	</div>
	<nav class="navbar navbar-header navbar-expand-lg">
		<div class="container-fluid">

			<form class="navbar-left navbar-form nav-search mr-md-3" action="">
				<div class="input-group">
					<input type="text" placeholder="Ara..." class="form-control">
					<div class="input-group-append">
						<span class="input-group-text">
							<i class="la la-search search-icon"></i>
						</span>
					</div>
				</div>
			</form>
			<ul class="navbar-nav topbar-nav ml-md-auto align-items-center">
				<li class="nav-item dropdown hidden-caret">
					<a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
						<i class="la la-envelope"></i>
					</a>
				</li>
				<li class="nav-item dropdown hidden-caret">
					<a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
						<i class="la la-bell"></i>
						@if (ViewBag.toDoListCount > 0)
						{
							<span class="notification">@ViewBag.toDoListCount</span>
						}
					</a>
					<ul class="dropdown-menu notif-box" aria-labelledby="navbarDropdown">
						<li>
							<div class="dropdown-title">@ViewBag.toDoListCount Yeni Bildirim</div>
						</li>
						<li>
							<div class="notif-center">
								@foreach (var item in Model)
								{
									<a href="#">
										<div class="notif-icon notif-primary"> <i class="@item.ImageUrl"></i> </div>
										<div class="notif-content">
											<span class="block">
												@item.Title
											</span>
											<span class="time">@item.Date.ToShortDateString()</span>
										</div>
									</a>
								}
							</div>
						</li>
						<li>
							<a class="see-all" href="/ToDoList/Index"> <strong>Tüm bildirimleri gör...</strong> <i class="la la-angle-right"></i> </a>
						</li>
					</ul>
				</li>
				<li class="nav-item dropdown">
					<a class="dropdown-toggle profile-pic" data-toggle="dropdown" href="#" aria-expanded="false"> <img src="~/AdminPanelTemplate/assets/img/profile.jpg" alt="user-img" width="36" class="img-circle"><span>Admin</span></a>
					<ul class="dropdown-menu dropdown-user">
						<li>
							<div class="user-box">
								<div class="u-img"><img src="~/AdminPanelTemplate/assets/img/profile.jpg" alt="user"></div>
								<div class="u-text">
									<h6>Burak Can Yurdacan</h6>
									<a href="#" class="btn btn-rounded btn-danger btn-sm">Profili Gör</a>
								</div>
							</div>
						</li>
						<div class="dropdown-divider"></div>
						<a class="dropdown-item" href="/Skill/ListSkills"></i> Yeteneklerim</a>
						<a class="dropdown-item" href="/Message/Inbox"><i class="ti-email"></i> Gelen Kutusu</a>
						<div class="dropdown-divider"></div>
						<a class="dropdown-item" href="#"><i class="fa fa-power-off"></i> Çıkış Yap</a>
					</ul>
					<!-- /.dropdown-user -->
				</li>
			</ul>
		</div>
	</nav>
</div>