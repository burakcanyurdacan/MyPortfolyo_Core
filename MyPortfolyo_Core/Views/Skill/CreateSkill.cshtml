@model Skill
@{
    ViewData["Title"] = "CreateSkill";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="content">
    <div class="container-fluid">
        <h4 class="page-title">Yetenek Ekle</h4>
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-body">
                        <form method="post">
                            <label>Yetenek Adı</label>
                            <input type="text" asp-for="Title" class="form-control text-uppercase" />
                            <br />
                            <label>Yetenek Seviyesi:</label>
                            <input type="number" class="form-control" min="0" max="100" step="5" asp-for="Value" value="0" />
                            <br />
                            <button class="btn btn-success">Ekle</button>&nbsp;&nbsp;
                            <a asp-controller="Skill" asp-action="ListSkills" class="btn btn-secondary">Geri Dön</a>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>