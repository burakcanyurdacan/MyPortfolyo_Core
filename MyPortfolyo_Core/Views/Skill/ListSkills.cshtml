@model List<Skill>
@{
    ViewData["Title"] = "ListSkills";
    Layout = "~/Views/Layout/Index.cshtml";
    string progValue;
}

<div class="content">
    <div class="container-fluid">
        <h4 class="page-title">Yeteneklerim</h4>
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header">
                        <div class="card-title">Program Dilleri ve Teknolojiler</div>
                    </div>
                    <div class="card-body">
                        <div class="card-sub">
                            Yeteneklerle ilgili işlemleri aşağıdaki panelden yapabilirsiniz.
                        </div>
                        <table class="table mt-3">
                            <thead>
                                <tr>
                                    <th scope="col">Başlık</th>
                                    <th scope="col">Yetenek Değeri</th>
                                    <th scope="col">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    progValue = item.Value.ToString()+"%";
                                    <tr>
                                        <td>@item.Title</td>
                                        <td>
                                            <div class="progress">
                                                <div class="progress-bar bg-primary" role="progressbar" style="width: @progValue" aria-valuenow="@item.Value" aria-valuemin="0" aria-valuemax="100">@progValue</div>
                                            </div>
                                        </td>
                                        <td>
                                            <a href="/Skill/DeleteSkill/@item.SkillId" class="btn btn-danger" title="Sil"><i class="la la-trash"></i></a>
                                            <a href="/Skill/UpdateSkill/@item.SkillId" class="btn btn-info" title="Güncelle"><i class="la la-pencil"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <hr />
                        <a href="/Skill/CreateSkill" class="btn btn-primary"><i class="la la-plus"></i>&nbsp;Yetenek Ekle</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>