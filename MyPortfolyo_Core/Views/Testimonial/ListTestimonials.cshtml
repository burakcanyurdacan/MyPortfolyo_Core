@model List<Testimonial>

@{
    ViewData["Title"] = "ListTestimonials";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="content">
    <div class="container-fluid">
        <h4 class="page-title">Referanslarım</h4>
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header">
                        <div class="card-title">Referans Listesi</div>
                    </div>
                    <div class="card-body">
                        <div class="card-sub">
                            Referanslarla ilgili işlemleri aşağıdaki panelden yapabilirsiniz.
                        </div>
                        <table class="table mt-3">
                            <thead>
                                <tr>
                                    <th scope="col">Görsel</th>
                                    <th scope="col">Ad - Soyad</th>
                                    <th scope="col">Unvan</th>
                                    <th scope="col">Açıklama</th>
                                    <th scope="col">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <img src="@item.ImageUrl" alt="user-img" width="45" class="rounded-circle"/>
                                        </td>
                                        <td>@item.NameSurname</td>
                                        <td>@item.Title</td>
                                        <td>@item.Description</td>
                                        <td class="col-1">
                                            <a href="/Testimonial/DeleteTestimonial/@item.TestimonialId" class="btn btn-danger" title="Sil"><i class="la la-trash"></i></a>
                                            <a href="/Testimonial/UpdateTestimonial/@item.TestimonialId" class="btn btn-info" title="Güncelle"><i class="la la-pencil"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <hr />
                        <a href="/Testimonial/AddTestimonial" class="btn btn-primary"><i class="la la-plus"></i>&nbsp;Referans Ekle</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>